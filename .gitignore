# ───────────────────────────────
# AI & Cursor
# ───────────────────────────────
.cursor/
.cursorignore
.cursorrules         # keep this if you want rules in version control, remove if not
.claude/
.anthropic/

# ───────────────────────────────
# OS junk
# ───────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ───────────────────────────────
# Editors
# ───────────────────────────────
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# ───────────────────────────────
# Node / npm (if you add a build step later)
# ───────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.npm
.yarn/cache

# ───────────────────────────────
# Build output
# ───────────────────────────────
dist/
build/
.cache/
.parcel-cache/
.next/
out/

# ───────────────────────────────
# Environment & secrets — NEVER commit these
# ───────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# Python cache
__pycache__/
*.pyc
